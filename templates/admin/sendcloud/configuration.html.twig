{% extends '@SyliusAdmin/shared/layout/base.html.twig' %}

{% block title %}SendCloud — Configuration | {{ parent() }}{% endblock %}

{% block body %}
<div class="ui padded segment">
    <div class="ui two column stackable grid">
        <div class="column">
            <h1 class="ui header">
                <i class="truck icon"></i>
                <div class="content">
                    SendCloud
                    <div class="sub header">{{ 'spiderweb_sendcloud.ui.configuration_subtitle'|trans }}</div>
                </div>
            </h1>

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="ui {{ label == 'success' ? 'positive' : 'negative' }} message">
                        {{ message|trans }}
                    </div>
                {% endfor %}
            {% endfor %}

            {{ form_start(form, {attr: {class: 'ui form', novalidate: 'novalidate'}}) }}

            <div class="ui segment">
                <h3 class="ui dividing header">{{ 'spiderweb_sendcloud.ui.api_credentials'|trans }}</h3>

                <div class="field {% if form.publicKey.vars.errors|length %}error{% endif %}">
                    {{ form_label(form.publicKey) }}
                    {{ form_widget(form.publicKey) }}
                    {{ form_errors(form.publicKey) }}
                    {% if not is_new %}<small class="ui grey text">{{ 'spiderweb_sendcloud.form.key_edit_hint'|trans }}</small>{% endif %}
                </div>

                <div class="field {% if form.privateKey.vars.errors|length %}error{% endif %}">
                    {{ form_label(form.privateKey) }}
                    {{ form_widget(form.privateKey) }}
                    {{ form_errors(form.privateKey) }}
                    <small class="ui grey text">{{ 'spiderweb_sendcloud.ui.private_key_help'|trans }}</small>
                    {% if not is_new %}<small class="ui grey text">{{ 'spiderweb_sendcloud.form.key_edit_hint'|trans }}</small>{% endif %}
                </div>

                <div class="inline field">
                    {{ form_widget(form.enabled) }}
                    {{ form_label(form.enabled) }}
                </div>
            </div>

            <div class="ui segment secondary">
                <p>
                    <i class="info circle icon"></i>
                    {{ 'spiderweb_sendcloud.ui.encryption_notice'|trans }}
                </p>
            </div>

            <button type="submit" class="ui primary button">
                <i class="save icon"></i>
                {{ 'sylius.ui.save_changes'|trans }}
            </button>

            {{ form_end(form) }}
        </div>

        {% if configuration.id is not null %}
        <div class="column">
            <div class="ui info message">
                <div class="header">{{ 'spiderweb_sendcloud.ui.status'|trans }}</div>
                <p>
                    {% if configuration.enabled %}
                        <i class="green check circle icon"></i> {{ 'spiderweb_sendcloud.ui.status_active'|trans }}
                    {% else %}
                        <i class="red times circle icon"></i> {{ 'spiderweb_sendcloud.ui.status_disabled'|trans }}
                    {% endif %}
                </p>
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
