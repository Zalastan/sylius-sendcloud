{#
  Injected at priority -200 in sylius_shop.checkout.select_shipping.content.form.
  For each SendCloud method with enable_checkout_override=true:
    - hides the static "SendCloud: 0€" card
    - auto-loads delivery options from SendCloud in its place
    - selecting an option auto-checks the hidden Sylius radio and
      triggers a LiveComponent re-render so the price updates
#}
{% set form = hookable_metadata.context.form %}
{% set order = hookable_metadata.context.order %}

{% set sc_methods = {} %}
{% for form_shipment in form.shipments %}
    {% for choice in form_shipment.method.vars.choices %}
        {% set method = choice.data %}
        {% if method.calculator == 'sendcloud' and (method.configuration.enable_checkout_override ?? false) %}
            {% set sc_methods = sc_methods|merge({(method.id ~ ''): true}) %}
        {% endif %}
    {% endfor %}
{% endfor %}

{% if sc_methods is not empty %}
<template id="sendcloud-options-tpl">
    <div class="sendcloud-options-panel">
        <div class="sendcloud-loading text-muted small py-2">
            {{ 'spiderweb_sendcloud.checkout.loading_options'|trans }}
        </div>
        <div class="sendcloud-options-list"></div>
        <div class="sendcloud-options-error alert alert-warning mt-2" style="display:none;">
            {{ 'spiderweb_sendcloud.checkout.options_error'|trans }}
        </div>
    </div>
</template>

<script>
(function () {
    const SC_METHODS = {{ sc_methods|json_encode|raw }};
    const DELIVERY_OPTIONS_URL = '{{ path('spiderweb_sendcloud_delivery_options') }}';
    const SELECT_OPTION_URL = '{{ path('spiderweb_sendcloud_select_option') }}';
    const CHOOSE_LABEL = {{ ('spiderweb_sendcloud.checkout.choose_delivery_option'|trans)|json_encode|raw }};
    const NO_OPTIONS_LABEL = {{ ('spiderweb_sendcloud.checkout.no_options'|trans)|json_encode|raw }};

    function formatPrice(rate, locale) {
        if (rate && rate.value !== null) {
            return new Intl.NumberFormat(locale, {
                style: 'currency',
                currency: rate.currency || 'EUR',
            }).format(parseFloat(rate.value));
        }
        return '';
    }

    function clonePanel() {
        return document.getElementById('sendcloud-options-tpl').content.cloneNode(true);
    }

    function initMethod(methodId) {
        // Find the Sylius radio button for this method
        const radio = document.querySelector('input[type="radio"][value="' + methodId + '"]');
        if (!radio) return;

        // Find the wrapping card and hide it
        const card = radio.closest('.card');
        if (!card) return;
        card.style.display = 'none';

        // Insert our panel after the hidden card
        const panel = clonePanel().querySelector('.sendcloud-options-panel');
        panel.dataset.methodId = methodId;

        const title = document.createElement('h6');
        title.className = 'mb-3';
        title.textContent = CHOOSE_LABEL;
        panel.insertBefore(title, panel.firstChild);

        card.parentNode.insertBefore(panel, card.nextSibling);

        // Auto-load options immediately
        loadOptions(methodId, panel);
    }

    function loadOptions(methodId, panel) {
        const loading = panel.querySelector('.sendcloud-loading');
        const list = panel.querySelector('.sendcloud-options-list');
        const error = panel.querySelector('.sendcloud-options-error');

        loading.style.display = '';
        list.innerHTML = '';
        error.style.display = 'none';

        fetch(DELIVERY_OPTIONS_URL + '?method_id=' + methodId)
            .then(function (r) { return r.json(); })
            .then(function (data) {
                loading.style.display = 'none';
                if (data.error || !Array.isArray(data.options)) {
                    error.style.display = '';
                    return;
                }
                renderOptions(data.options, data.order_token, methodId, panel);
            })
            .catch(function () {
                loading.style.display = 'none';
                error.style.display = '';
            });
    }

    function renderOptions(options, orderToken, methodId, panel) {
        const list = panel.querySelector('.sendcloud-options-list');
        list.innerHTML = '';

        if (options.length === 0) {
            list.innerHTML = '<p class="text-muted small mb-0">' + NO_OPTIONS_LABEL + '</p>';
            return;
        }

        const locale = document.documentElement.lang || 'fr';

        options.forEach(function (option) {
            const identifier = (option.checkout_identifier || {}).value || (option.id + '');
            const title = option.title || option.internal_title || identifier;
            const price = formatPrice(option.shipping_rate, locale);
            const carrier = (option.carrier || {}).name || '';
            const logoUrl = (option.carrier || {}).logo_url || '';

            const div = document.createElement('div');
            div.className = 'card border mb-2';
            div.innerHTML =
                '<label class="d-flex align-items-center gap-3 card-body py-2 mb-0" style="cursor:pointer;">' +
                '<input type="radio" name="sendcloud_delivery_option_' + methodId + '" value="' + identifier + '" class="flex-shrink-0">' +
                (logoUrl ? '<img src="' + logoUrl + '" alt="' + carrier + '" style="height:24px;object-fit:contain;flex-shrink:0;">' : '') +
                '<span class="flex-grow-1">' + title + '</span>' +
                (price ? '<span class="fw-semibold flex-shrink-0">' + price + '</span>' : '') +
                '</label>';

            div.querySelector('input').addEventListener('change', function () {
                // Visual highlight
                panel.querySelectorAll('.sendcloud-options-list .card').forEach(function (c) {
                    c.classList.remove('border-primary');
                });
                div.classList.add('border-primary');

                // Save to cache then trigger Sylius price recalculation
                fetch(SELECT_OPTION_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ option_code: identifier, order_token: orderToken }),
                })
                .then(function () {
                    // Auto-check the hidden Sylius radio and trigger a change so
                    // the LiveComponent recalculates the shipping price
                    const syliusRadio = document.querySelector('input[type="radio"][value="' + methodId + '"]');
                    if (syliusRadio) {
                        syliusRadio.checked = true;
                        syliusRadio.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                })
                .catch(function (e) { console.error('SendCloud: failed to save option', e); });
            });

            list.appendChild(div);
        });
    }

    function init() {
        Object.keys(SC_METHODS).forEach(function (methodId) {
            initMethod(methodId);
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
{% endif %}
